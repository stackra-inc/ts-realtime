{
  "name": "@stackra/ts-realtime",
  "version": "1.0.1",
  "description": "Platform-agnostic Laravel Echo wrapper with DI module, typed channels, reconnection, and React hooks for real-time WebSocket communication",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "peerDependencies": {
    "@heroui-pro/react": "^1.0.0-beta.3",
    "@stackra/ts-container": "*",
    "@stackra/ts-coordinator": "*",
    "@stackra/ts-events": "*",
    "@stackra/ts-http": "*",
    "@stackra/ts-logger": "*",
    "@stackra/ts-redis": "*",
    "@stackra/ts-support": "*",
    "react": "^19.2.6"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "@stackra/ts-coordinator": {
      "optional": true
    },
    "@stackra/ts-events": {
      "optional": true
    },
    "@stackra/ts-http": {
      "optional": true
    },
    "@stackra/ts-logger": {
      "optional": false
    },
    "@stackra/ts-redis": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@heroui-pro/react": "^1.0.0-beta.3",
    "@stackra/testing": "workspace:*",
    "@stackra/ts-container": "github:stackra-inc/ts-container#main",
    "@stackra/ts-coordinator": "github:stackra-inc/ts-coordinator#main",
    "@stackra/ts-events": "github:stackra-inc/ts-events#main",
    "@stackra/ts-http": "github:stackra-inc/ts-http#main",
    "@stackra/ts-logger": "github:stackra-inc/ts-logger#main",
    "@stackra/ts-redis": "github:stackra-inc/ts-redis#main",
    "@stackra/ts-support": "github:stackra-inc/ts-support#main",
    "@stackra/typescript-config": "^1.0.12",
    "@types/react": "^19.2.14",
    "fast-check": "^4.8.0",
    "jiti": "^2.7.0",
    "react": "^19.2.6"
  },
  "dependencies": {
    "@stackra/contracts": "github:stackra-inc/contracts#main",
    "laravel-echo": "^2.3.4",
    "pusher-js": "^8.5.0"
  }
}
